{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "../dist/types",
    "rootDir": "../src",
    "skipLibCheck": true,
    "incremental": false,
    "composite": false
  },
  "include": ["../src/**/*.ts", "../src/**/*.tsx"],
  "exclude": ["../node_modules", "../src/**/*.test.ts", "../src/**/*.test.tsx"]
}
